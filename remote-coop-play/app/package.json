{
  "name": "remote-coop-play-client",
  "version": "1.0.0",
  "private": true,
  "description": "Electron Windows client for Remote Coop Play.",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron .",
    "dist:win": "electron-builder --win portable nsis",
    "build:win": "electron-builder --win",
    "dist": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ensamprompters.remotecoopplay",
    "productName": "Remote Coop Play",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true,
    "asarUnpack": [
      "src/native/**"
    ]
  }
}